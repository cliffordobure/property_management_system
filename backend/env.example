MONGODB_URI=mongodb://localhost:27017/turbine
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production_minimum_32_characters
PORT=5000
NODE_ENV=development

# Frontend URL for CORS (comma-separated for multiple URLs)
# Example: FRONTEND_URL=https://your-app.vercel.app,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

# Encryption key for bank account credentials (must be 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Africa's Talking SMS Configuration (Optional - can be set per organization)
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=your_africas_talking_username
